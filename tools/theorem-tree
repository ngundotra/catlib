def find_lean_files(path):
    """Find all .lean files under a path."""
    path = Path(path)
    if path.is_file():
        if path.suffix == ".lean":
            return [str(path)]
        return []
    elif path.is_dir():
        files = []
        for root_dir, dirs, filenames in os.walk(path):
            dirs[:] = [d for d in dirs if not d.startswith(".") and d != ".lake"]
            for fn in sorted(filenames):
                if fn.endswith(".lean"):
                    files.append(os.path.join(root_dir, fn))
        return files
    return []


