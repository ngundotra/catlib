def main():
    args = sys.argv[1:]

    if not args or "--help" in args or "-h" in args:
        print(__doc__.strip())
        print()
        print("Regex mode (fast, no build needed):")
        print("  --connections        Show cross-file connections only")
        print("  --axioms-only        Show only axiom declarations")
        print("  --theorems-only      Show only theorem declarations")
        print("  --defs-only          Show only def declarations")
        print("  --brief              One-line descriptions with metadata (default)")
        print("  --verbose            Full multi-line docstrings")
        print("  --flow               Sankey-style left-to-right dependency flow")
        print("  --trace NAME         Trace all dependencies of a declaration")
        print("  --defs               Show definitions and their theorem connections")
        print()
        print("Kernel mode (slow, requires `lake build`):")
        print("  --true-islands       Kernel-verified unused axioms (axiom-only)")
        print("  --kernel NAME        Kernel-verified deps for a theorem")
        print("  --compare            Compare regex vs kernel dependency detection")
        print("  --json               JSON output of kernel dependency report")
        print("  --props              Proposition-centric analysis (what has been proven)")
        print()
        print("  -h, --help           Show this help message")
        sys.exit(0)

    connections_only = False
    filter_kind = None
    target_path = None
    verbose = False
    flow_mode = False
    trace_name = None
    defs_mode = False
    # Kernel mode flags
    kernel_mode = None   # "true-islands", "kernel", "compare", "full"
    kernel_name = None
    kernel_json = False

    i = 0
    while i < len(args):
        arg = args[i]
        if arg == "--connections":
            connections_only = True
        elif arg == "--axioms-only":
            filter_kind = {"axiom"}
        elif arg == "--theorems-only":
            filter_kind = {"theorem"}
        elif arg == "--defs-only":
            filter_kind = {"def"}
        elif arg == "--verbose":
            verbose = True
        elif arg == "--brief":
            verbose = False
        elif arg == "--flow":
            flow_mode = True
        elif arg == "--trace":
            i += 1
            if i >= len(args):
                print("Error: --trace requires a theorem name", file=sys.stderr)
                sys.exit(1)
            trace_name = args[i]
        elif arg == "--defs":
            defs_mode = True
        # Kernel mode flags
        elif arg == "--true-islands":
            kernel_mode = "true-islands"
        elif arg == "--kernel":
            kernel_mode = "kernel"
            i += 1
            if i >= len(args):
                print("Error: --kernel requires a theorem name", file=sys.stderr)
                sys.exit(1)
            kernel_name = args[i]
        elif arg == "--compare":
            kernel_mode = "compare"
        elif arg == "--json":
            kernel_json = True
            if not kernel_mode:
                kernel_mode = "full"
        elif arg == "--props":
            kernel_mode = "props"
        else:
            target_path = arg
        i += 1

    if not target_path:
        print("Error: no path specified", file=sys.stderr)
        sys.exit(1)

    if not os.path.isabs(target_path):
        target_path = os.path.join(os.getcwd(), target_path)

    if not os.path.exists(target_path):
        print(f"Error: path not found: {target_path}", file=sys.stderr)
        sys.exit(1)

    # Kernel mode: dispatch early (no need for regex parsing)
    if kernel_mode:
        _run_kernel_mode(kernel_mode, kernel_name, kernel_json, target_path)
        return

    # Find project root
    root = os.getcwd()
    check = root
    for _ in range(10):
        if os.path.exists(os.path.join(check, "lakefile.lean")):
            root = check
            break
        parent = os.path.dirname(check)
        if parent == check:
            break
        check = parent

    # Find target files
    lean_files = find_lean_files(target_path)
    if not lean_files:
        print(f"No .lean files found under {target_path}", file=sys.stderr)
        sys.exit(1)

    # Parse the full project for cross-file reference resolution
    all_project_files = find_lean_files(os.path.join(root, "Catlib"))
    all_parsed = []
    for fp in all_project_files:
        all_parsed.append(parse_lean_file(fp))

    resolve_references(all_parsed)

    # Filter to target files for display
    target_set = set(os.path.abspath(f) for f in lean_files)
    target_parsed = [lf for lf in all_parsed if os.path.abspath(lf.path) in target_set]

    if not target_parsed:
        print(f"No declarations found in {target_path}", file=sys.stderr)
        sys.exit(1)

    rel_target = make_relative(target_path, root)

    # Dispatch to the appropriate mode
    graph_mode = any([trace_name, defs_mode])

    if graph_mode:
        # Graph query modes operate on all parsed files in the target scope
        if trace_name:
            print_trace(all_parsed, root, trace_name)
        elif defs_mode:
            print_defs(target_parsed, root)
    elif flow_mode:
        print(f"Dependency Flow: {rel_target}")
        print("=" * 60)
        print()
        print_flow(target_parsed, all_parsed, root)
    else:
        print(f"Theorem Tree: {rel_target}")
        print("=" * 60)
        print()
        print_tree(target_parsed, root, filter_kind=filter_kind,
                   connections_only=connections_only, verbose=verbose)

    # Summary
    if not connections_only and not flow_mode and not graph_mode:
        print()
        total = sum(len(lf.declarations) for lf in target_parsed)
        by_kind = defaultdict(int)
        for lf in target_parsed:
            for d in lf.declarations:
                if filter_kind and d.kind not in filter_kind:
                    continue
                by_kind[d.kind] += 1

        parts = [f"{count} {kind}{'s' if count != 1 else ''}"
                 for kind, count in sorted(by_kind.items())]
        if filter_kind:
            shown = sum(by_kind.values())
            print(f"Summary: {shown} of {total} declarations shown ({', '.join(parts)})")
        else:
            print(f"Summary: {total} declarations ({', '.join(parts)})")


if __name__ == "__main__":
    main()
