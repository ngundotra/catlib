def _build_decl_index(all_parsed):
    """Build a name -> Declaration index from all parsed files."""
    index = {}
    for lf in all_parsed:
        for decl in lf.declarations:
            if decl.name.endswith("_tag") or decl.name.endswith("_provenance"):
                continue
            index[decl.name] = decl
    return index


def _transitive_dependents(name, decl_index):
    """Find all declarations that transitively depend on `name`."""
    dependents = set()
    # Build reverse map: for each decl, which decls reference it?
    used_by = defaultdict(set)
    for dname, decl in decl_index.items():
        for ref in decl.references:
            if ref in decl_index:
                used_by[ref].add(dname)

    # BFS from name
    queue = [name]
    visited = {name}
    while queue:
        current = queue.pop(0)
        for dep in used_by.get(current, set()):
            if dep not in visited:
                visited.add(dep)
                dependents.add(dep)
                queue.append(dep)
    return dependents


def _transitive_dependencies(name, decl_index):
    """Find all declarations that `name` transitively depends on."""
    dependencies = set()
    queue = [name]
    visited = {name}
    while queue:
        current = queue.pop(0)
        decl = decl_index.get(current)
        if not decl:
            continue
        for ref in decl.references:
            if ref in decl_index and ref not in visited:
                visited.add(ref)
                dependencies.add(ref)
                queue.append(ref)
    return dependencies




def print_trace(all_parsed, root, theorem_name):
    """Trace all transitive dependencies of a theorem as a tree."""
    decl_index = _build_decl_index(all_parsed)

    if theorem_name not in decl_index:
        print(f"Error: declaration '{theorem_name}' not found", file=sys.stderr)
        # Suggest close matches
        candidates = [n for n in decl_index if theorem_name.lower() in n.lower()]
        if candidates:
            print(f"Did you mean: {', '.join(candidates[:5])}", file=sys.stderr)
        sys.exit(1)

    root_decl = decl_index[theorem_name]

    print(f"Dependency trace: {theorem_name}")
    print("=" * 60)
    print()

    def _print_dep_tree(name, prefix="", visited=None):
        if visited is None:
            visited = set()

        decl = decl_index.get(name)
        if not decl:
            return

        # Get direct dependencies
        direct_deps = [ref for ref in decl.references if ref in decl_index]

        for i, dep_name in enumerate(direct_deps):
            dep_decl = decl_index[dep_name]
            is_last = (i == len(direct_deps) - 1)
            connector = "\u2514\u2500\u2500 " if is_last else "\u251c\u2500\u2500 "
            child_prefix = "    " if is_last else "\u2502   "

            kind_tag = f"[{dep_decl.kind}]"
            # Show cross-file origin
            file_note = ""
            if dep_decl.file_path != decl.file_path:
                file_note = f" (from {os.path.basename(dep_decl.file_path).replace('.lean', '')})"

            cycle_note = ""
            if dep_name in visited:
                cycle_note = " [circular]"

            print(f"{prefix}{connector}{kind_tag} {dep_name}{file_note}{cycle_note}")

            if dep_name not in visited:
                visited.add(dep_name)
                _print_dep_tree(dep_name, prefix + child_prefix, visited)

    kind_tag = f"[{root_decl.kind}]"
    rel_file = make_relative(root_decl.file_path, root)
    print(f"{kind_tag} {theorem_name} ({rel_file})")
    visited = {theorem_name}
    _print_dep_tree(theorem_name, "", visited)

    # Summary
    all_deps = _transitive_dependencies(theorem_name, decl_index)
    by_kind = defaultdict(list)
    for dep in all_deps:
        by_kind[decl_index[dep].kind].append(dep)
    print()
    parts = [f"{len(v)} {k}{'s' if len(v) != 1 else ''}" for k, v in sorted(by_kind.items())]
    print(f"Total transitive dependencies: {len(all_deps)} ({', '.join(parts)})")


def print_defs(all_parsed, root):
    """Show definitions and which theorems use them."""
    decl_index = _build_decl_index(all_parsed)

    # Build reverse map: for each def, which theorems reference it?
    def_names = [name for name, decl in decl_index.items()
                 if decl.kind == "def"]

    results = []
    for dname in def_names:
        deps = _transitive_dependents(dname, decl_index)
        # Direct theorem users (not transitive — more useful for defs)
        direct_users = []
        for uname, udecl in decl_index.items():
            if dname in udecl.references:
                direct_users.append(uname)

        results.append((dname, sorted(direct_users)))

    results.sort(key=lambda x: len(x[1]), reverse=True)

    print("Definitions and their theorem connections:")
    print("=" * 60)
    print()
    for name, users in results:
        decl = decl_index[name]
        rel_file = os.path.basename(decl.file_path).replace(".lean", "")
        if users:
            user_list = ", ".join(users[:10])
            if len(users) > 10:
                user_list += f", ... (+{len(users) - 10} more)"
            print(f"  [def] {name} ({rel_file}) -> used by: {user_list}")
        else:
            print(f"  [def] {name} ({rel_file}) -> (unused)")
    print()
    used_count = sum(1 for _, users in results if users)
    print(f"Total: {len(results)} defs ({used_count} used, {len(results) - used_count} unused)")



