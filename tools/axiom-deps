#!/usr/bin/env python3
"""
axiom-deps: Ground-truth axiom dependency analysis using Lean's kernel.

Uses `#print axioms` via `lake env lean` to get the TRUE dependency graph
for every theorem in catlib — no regex approximation, no guessing.

Usage:
    ./tools/axiom-deps Catlib/                            # Full report
    ./tools/axiom-deps --theorem NAME Catlib/             # Single theorem
    ./tools/axiom-deps --compare Catlib/                  # Compare regex vs kernel
    ./tools/axiom-deps --true-islands Catlib/             # Axioms no theorem uses (kernel-verified)
    ./tools/axiom-deps --json Catlib/                     # JSON output
"""

import json
import os
import re
import subprocess
import sys
import tempfile
from collections import defaultdict
from pathlib import Path


# ---------------------------------------------------------------------------
# Lean source scanning
# ---------------------------------------------------------------------------

THEOREM_RE = re.compile(r"^theorem\s+(\S+)")
NAMESPACE_RE = re.compile(r"^namespace\s+(\S+)")
END_NAMESPACE_RE = re.compile(r"^end\s+(\S+)")
AXIOM_RE = re.compile(r"^(axiom|opaque)\s+(\S+)")

# Valid Lean identifier: must start with a letter or underscore
VALID_IDENT_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")

# Lean built-in axioms to filter out
LEAN_BUILTINS = {
    "propext", "Quot.mk", "Classical.choice", "Quot.sound",
    "Quot.ind", "Quot.lift", "rfl", "Eq.refl",
}


def scan_declarations(root_path):
    """Scan all .lean files for theorem and axiom declarations.

    Returns:
        theorems: list of (fqn, file_path, line_no)
        axioms: list of (fqn, file_path, line_no)
    """
    theorems = []
    axioms = []
    root = Path(root_path)

    lean_files = sorted(root.rglob("*.lean"))
    # Exclude module-level import files (Catlib.lean, Creed.lean, etc.)
    lean_files = [f for f in lean_files if not _is_import_only(f)]

    for filepath in lean_files:
        try:
            lines = filepath.read_text(encoding="utf-8").splitlines()
        except (IOError, UnicodeDecodeError):
            continue

        # Track namespace stack and comment blocks
        ns_stack = []
        in_block_comment = False

        for i, line in enumerate(lines, 1):
            stripped = line.strip()

            # Track block comments (/-! ... -/ and /-- ... -/)
            if not in_block_comment:
                if stripped.startswith("/-"):
                    in_block_comment = True
                    if "-/" in stripped[2:]:
                        in_block_comment = False
                    continue
            else:
                if "-/" in stripped:
                    in_block_comment = False
                continue

            # Skip line comments
            if stripped.startswith("--"):
                continue

            # Use the raw line for matching — declarations must start at col 0
            # (no leading whitespace) to avoid matching inside comments/docstrings
            m = NAMESPACE_RE.match(line)
            if m:
                ns_stack.append(m.group(1))
                continue

            m = END_NAMESPACE_RE.match(line)
            if m:
                # Pop matching namespace
                end_ns = m.group(1)
                if ns_stack and ns_stack[-1] == end_ns:
                    ns_stack.pop()
                continue

            current_ns = ns_stack[-1] if ns_stack else ""

            m = THEOREM_RE.match(line)
            if m:
                name = m.group(1).rstrip(":").rstrip("(")
                if not VALID_IDENT_RE.match(name):
                    continue
                fqn = f"{current_ns}.{name}" if current_ns else name
                theorems.append((fqn, str(filepath), i))
                continue

            m = AXIOM_RE.match(line)
            if m:
                kind = m.group(1)
                name = m.group(2).rstrip(":").rstrip("(")
                if not VALID_IDENT_RE.match(name):
                    continue
                fqn = f"{current_ns}.{name}" if current_ns else name
                axioms.append((fqn, str(filepath), i, kind))


    return theorems, axioms


def _is_import_only(filepath):
    """Check if a file is just imports (module aggregator files)."""
    try:
        text = filepath.read_text(encoding="utf-8")
        # If file only has imports, comments, and whitespace, skip it
        for line in text.splitlines():
            stripped = line.strip()
            if stripped and not stripped.startswith("import") and not stripped.startswith("--"):
                return False
        return True
    except:
        return False


# ---------------------------------------------------------------------------
# Lean kernel interrogation
# ---------------------------------------------------------------------------

def run_print_axioms(theorem_fqns, batch_size=50):
    """Generate a temp Lean file with #print axioms for each theorem, run it.

    Returns dict: { theorem_fqn: [list of axiom fqns] }
    """
    results = {}
    errors = {}

    # Process in batches to avoid overly large files
    for batch_start in range(0, len(theorem_fqns), batch_size):
        batch = theorem_fqns[batch_start:batch_start + batch_size]
        batch_num = batch_start // batch_size + 1
        total_batches = (len(theorem_fqns) + batch_size - 1) // batch_size

        print(f"  Processing batch {batch_num}/{total_batches} "
              f"({len(batch)} theorems)...", file=sys.stderr)

        with tempfile.NamedTemporaryFile(
            mode="w", suffix=".lean", delete=False, prefix="axiom_deps_"
        ) as f:
            f.write("import Catlib\n\n")
            for fqn in batch:
                f.write(f"#print axioms {fqn}\n")
            tmp_path = f.name

        try:
            proc = subprocess.run(
                ["lake", "env", "lean", tmp_path],
                capture_output=True, text=True, timeout=300,
            )
            output = proc.stdout + proc.stderr
            _parse_print_axioms_output(output, results, errors)
        except subprocess.TimeoutExpired:
            print(f"  WARNING: Batch {batch_num} timed out!", file=sys.stderr)
        finally:
            os.unlink(tmp_path)

    return results, errors


def _parse_print_axioms_output(output, results, errors):
    """Parse the output of multiple #print axioms commands.

    Format is:
        'Name' depends on axioms: [ax1, ax2, ...]
    or:
        'Name' does not depend on any axioms
    or multiline:
        'Name' depends on axioms: [ax1,
         ax2,
         ax3]
    """
    # Collect complete statements - handle multiline bracket lists
    buffer = ""
    for line in output.splitlines():
        line = line.strip()
        if not line:
            continue

        # Check for error lines
        if "unknown identifier" in line or "unknown constant" in line:
            # Try to extract the name from the error
            m = re.search(r"'([^']+)'", line)
            if m:
                errors[m.group(1)] = line
            continue

        if line.startswith("'") and "depends on" in line:
            buffer = line
        elif line.startswith("'") and "does not depend" in line:
            buffer = line
        elif buffer:
            buffer += " " + line
        else:
            continue

        # Check if buffer is complete (has closing bracket or "does not depend")
        if "does not depend" in buffer:
            m = re.match(r"'([^']+)'\s+does not depend on any axioms", buffer)
            if m:
                results[m.group(1)] = []
            buffer = ""
        elif "]" in buffer:
            m = re.match(r"'([^']+)'\s+depends on axioms:\s*\[(.+)\]", buffer)
            if m:
                name = m.group(1)
                axiom_str = m.group(2)
                axiom_list = [a.strip() for a in axiom_str.split(",") if a.strip()]
                results[name] = axiom_list
            buffer = ""


def filter_catlib_axioms(axiom_list):
    """Filter out Lean builtin axioms, keep only Catlib ones."""
    return [a for a in axiom_list if a not in LEAN_BUILTINS and not a.startswith("Lean.")]


# ---------------------------------------------------------------------------
# Report generation
# ---------------------------------------------------------------------------

def print_full_report(results, errors, source_axioms, source_theorems):
    """Print the full dependency report."""
    print("=" * 70)
    print("AXIOM DEPENDENCIES — Ground Truth (Lean Kernel)")
    print("=" * 70)
    print()

    # Collect all catlib axioms referenced by any theorem
    all_used_axioms = set()
    theorem_deps = {}

    for fqn, deps in sorted(results.items()):
        catlib_deps = filter_catlib_axioms(deps)
        theorem_deps[fqn] = catlib_deps
        all_used_axioms.update(catlib_deps)

    # Print per-theorem results
    print(f"Theorems analyzed: {len(results)}")
    if errors:
        print(f"Errors (could not resolve): {len(errors)}")
    print()

    for fqn, deps in sorted(theorem_deps.items()):
        lean_deps = [a for a in results.get(fqn, []) if a in LEAN_BUILTINS]
        print(f"  theorem {_short_name(fqn)}")
        if deps:
            for d in sorted(deps):
                print(f"    <- {_short_name(d)}")
        else:
            print(f"    (no Catlib axiom dependencies)")
        if lean_deps:
            print(f"    [Lean builtins: {', '.join(lean_deps)}]")
        print()

    # Summary
    print("-" * 70)
    print("SUMMARY")
    print("-" * 70)

    source_axiom_names = {fqn for fqn, _, _, _ in source_axioms}
    print(f"  Source axioms/opaques declared: {len(source_axiom_names)}")
    print(f"  Axioms referenced by theorems: {len(all_used_axioms)}")
    print(f"  Theorems analyzed: {len(results)}")
    print()

    # Axiom usage frequency
    axiom_usage = defaultdict(list)
    for fqn, deps in theorem_deps.items():
        for dep in deps:
            axiom_usage[dep].append(fqn)

    if axiom_usage:
        print("  Most-used axioms (by theorem count):")
        for ax, users in sorted(axiom_usage.items(), key=lambda x: -len(x[1]))[:15]:
            print(f"    {_short_name(ax)}: {len(users)} theorems")
        print()

    # True islands
    true_islands = source_axiom_names - all_used_axioms
    if true_islands:
        print(f"  TRUE ISLANDS — axioms no theorem depends on ({len(true_islands)}):")
        for ax in sorted(true_islands):
            print(f"    {_short_name(ax)}")
        print()

    if errors:
        print(f"  RESOLUTION ERRORS ({len(errors)}):")
        for name, err in sorted(errors.items()):
            print(f"    {name}: {err}")
        print()


def print_theorem_report(results, theorem_name):
    """Print dependencies for a single theorem."""
    # Find matching theorem
    matches = [fqn for fqn in results if theorem_name in fqn]
    if not matches:
        print(f"ERROR: No theorem matching '{theorem_name}' found in results.")
        print(f"  Available: {', '.join(sorted(results.keys())[:10])}...")
        sys.exit(1)

    for fqn in sorted(matches):
        deps = results[fqn]
        catlib_deps = filter_catlib_axioms(deps)
        lean_deps = [a for a in deps if a in LEAN_BUILTINS]

        print(f"theorem {fqn}")
        print(f"  Catlib dependencies ({len(catlib_deps)}):")
        for d in sorted(catlib_deps):
            print(f"    <- {d}")
        if lean_deps:
            print(f"  Lean builtins: {', '.join(lean_deps)}")
        print()


def print_true_islands(results, source_axioms):
    """Print axioms that no theorem depends on (kernel-verified).

    Only includes `axiom` declarations, not `opaque` type/relation definitions.
    """
    all_used = set()
    for deps in results.values():
        all_used.update(filter_catlib_axioms(deps))

    # Only consider `axiom` declarations, not `opaque` (types/relations are definitions)
    source_axiom_names = {fqn for fqn, _, _, kind in source_axioms if kind == "axiom"}
    islands = sorted(source_axiom_names - all_used)

    print("=" * 70)
    print("TRUE ISLANDS — Kernel-Verified Unused Axioms")
    print("=" * 70)
    print()
    print(f"Of {len(source_axiom_names)} declared axioms/opaques,")
    print(f"{len(islands)} are not used by ANY theorem (per Lean's kernel):")
    print()
    for ax in islands:
        print(f"  {ax}")
    print()


def print_compare_report(results, source_theorems, root_path):
    """Compare regex-based deps (from theorem-tree) vs kernel deps."""
    print("=" * 70)
    print("COMPARISON: Regex (theorem-tree) vs Kernel (#print axioms)")
    print("=" * 70)
    print()

    # Run theorem-tree --trace for each theorem and compare
    # Instead of invoking the other tool, we do our own simple regex scan
    # to see what names appear in theorem bodies

    from pathlib import Path

    # Build a set of all known axiom/opaque names for regex matching
    all_lean_files = sorted(Path(root_path).rglob("*.lean"))
    all_names = set()
    for f in all_lean_files:
        try:
            for line in f.read_text().splitlines():
                m = re.match(r"^(axiom|opaque)\s+(\S+)", line.strip())
                if m:
                    all_names.add(m.group(2).rstrip(":").rstrip("("))
        except:
            pass

    # For each theorem, scan its body for name mentions (simple regex approach)
    theorem_bodies = {}
    for fqn, filepath, lineno in source_theorems:
        try:
            lines = Path(filepath).read_text().splitlines()
            # Grab lines from theorem start until next top-level declaration or end
            body_lines = []
            for i in range(lineno - 1, len(lines)):
                line = lines[i]
                if i > lineno - 1 and re.match(r"^(axiom|theorem|def|structure|inductive|opaque|namespace|end)\s", line):
                    break
                body_lines.append(line)
            theorem_bodies[fqn] = "\n".join(body_lines)
        except:
            pass

    discrepancies = 0
    for fqn in sorted(results.keys()):
        kernel_deps = set(filter_catlib_axioms(results[fqn]))
        body = theorem_bodies.get(fqn, "")

        # Simple regex: which known names appear in the body?
        regex_deps = set()
        for name in all_names:
            if re.search(r'\b' + re.escape(name) + r'\b', body):
                regex_deps.add(name)

        # Compare (need to normalize — regex uses short names, kernel uses FQN)
        kernel_short = {_short_name(d) for d in kernel_deps}

        only_kernel = kernel_short - regex_deps
        only_regex = regex_deps - kernel_short

        if only_kernel or only_regex:
            discrepancies += 1
            print(f"  theorem {_short_name(fqn)}")
            if only_kernel:
                print(f"    MISSED by regex (kernel found): {', '.join(sorted(only_kernel))}")
            if only_regex:
                print(f"    FALSE POSITIVE (regex found, kernel didn't): {', '.join(sorted(only_regex))}")
            print()

    if discrepancies == 0:
        print("  No discrepancies found! (unlikely — check for errors)")
    else:
        print(f"  Total theorems with discrepancies: {discrepancies}/{len(results)}")
    print()


def print_json_report(results, errors, source_axioms):
    """Output JSON report."""
    all_used = set()
    theorem_data = {}
    for fqn, deps in sorted(results.items()):
        catlib_deps = filter_catlib_axioms(deps)
        lean_deps = [a for a in deps if a in LEAN_BUILTINS]
        all_used.update(catlib_deps)
        theorem_data[fqn] = {
            "catlib_deps": sorted(catlib_deps),
            "lean_builtins": sorted(lean_deps),
        }

    source_axiom_names = {fqn for fqn, _, _, _ in source_axioms}
    islands = sorted(source_axiom_names - all_used)

    report = {
        "theorems": theorem_data,
        "summary": {
            "theorems_analyzed": len(results),
            "source_axioms_declared": len(source_axiom_names),
            "axioms_used_by_theorems": len(all_used),
            "true_islands": islands,
        },
        "errors": errors,
    }
    print(json.dumps(report, indent=2))


def _short_name(fqn):
    """Strip common Catlib prefix for display."""
    for prefix in ["Catlib.MoralTheology.Suicide.",
                    "Catlib.MoralTheology.TheologyOfBody.",
                    "Catlib.MoralTheology.ConjugalEthics.",
                    "Catlib.MoralTheology.",
                    "Catlib.Creed.OriginalSin.",
                    "Catlib.Creed.",
                    "Catlib.Foundations.Love.",
                    "Catlib.Foundations.",
                    "Catlib.Sacraments.Reconciliation.",
                    "Catlib.Sacraments.",
                    "Catlib."]:
        if fqn.startswith(prefix):
            return fqn[len(prefix):]
    return fqn


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    args = sys.argv[1:]

    if not args or "-h" in args or "--help" in args:
        print(__doc__)
        sys.exit(0)

    # Parse flags
    mode = "full"
    theorem_filter = None
    json_mode = False

    filtered_args = []
    i = 0
    while i < len(args):
        if args[i] == "--theorem" and i + 1 < len(args):
            mode = "theorem"
            theorem_filter = args[i + 1]
            i += 2
        elif args[i] == "--compare":
            mode = "compare"
            i += 1
        elif args[i] == "--true-islands":
            mode = "islands"
            i += 1
        elif args[i] == "--json":
            json_mode = True
            i += 1
        else:
            filtered_args.append(args[i])
            i += 1

    root_path = filtered_args[0] if filtered_args else "Catlib/"

    # Step 1: Scan source for declarations
    print("Scanning Lean sources...", file=sys.stderr)
    theorems, axioms = scan_declarations(root_path)
    print(f"  Found {len(theorems)} theorems, {len(axioms)} axioms/opaques",
          file=sys.stderr)

    # Step 2: Determine which theorems to query
    if mode == "theorem" and theorem_filter:
        query_fqns = [fqn for fqn, _, _ in theorems if theorem_filter in fqn]
        if not query_fqns:
            print(f"ERROR: No theorem matching '{theorem_filter}'", file=sys.stderr)
            print(f"Available theorems:", file=sys.stderr)
            for fqn, _, _ in theorems[:20]:
                print(f"  {fqn}", file=sys.stderr)
            sys.exit(1)
    else:
        query_fqns = [fqn for fqn, _, _ in theorems]

    # Step 3: Run #print axioms via Lean kernel
    print(f"Running #print axioms on {len(query_fqns)} theorems...", file=sys.stderr)
    results, errors = run_print_axioms(query_fqns)
    print(f"  Got results for {len(results)} theorems", file=sys.stderr)
    if errors:
        print(f"  {len(errors)} errors", file=sys.stderr)
    print(file=sys.stderr)

    # Step 4: Output
    if json_mode:
        print_json_report(results, errors, axioms)
    elif mode == "theorem":
        print_theorem_report(results, theorem_filter)
    elif mode == "islands":
        print_true_islands(results, axioms)
    elif mode == "compare":
        print_compare_report(results, theorems, root_path)
    else:
        print_full_report(results, errors, axioms, theorems)


if __name__ == "__main__":
    main()
